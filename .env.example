# CaseFlow Environment Variables

# Mock mode (set to false to use real APIs)
MOCK_MODE=true

# LLM Provider (only needed when MOCK_MODE=false)
# Options: "anthropic", "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Web Search (only needed when MOCK_MODE=false)
# Options: "tavily", "serper"
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=

# CanLII API (future)
CANLII_API_KEY=
